# MultiChat Environment Configuration

# Database Settings
DB_TYPE=postgresql              # 'postgresql' or 'sqlserver'
DB_HOST=localhost               # Database host
DB_PORT=5432                    # Database port (5432 for PostgreSQL, 1433 for SQL Server)
DB_NAME=multichat               # Database name
DB_USER=multichat               # Database user
DB_PASS=multichat123            # Database password (change in production!)

# Server Settings
PORT=8080                       # HTTP Server port
TCP_PORT=5000                   # TCP Socket Server port (for desktop clients)
JAVA_OPTS=-Xmx512m             # JVM memory settings

# Application Settings
LOG_LEVEL=INFO                  # Logging level (DEBUG, INFO, WARN, ERROR)
MAX_CONNECTIONS=1000            # Max concurrent HTTP connections
MESSAGE_BUFFER_SIZE=200         # Max in-memory messages per room
SESSION_TIMEOUT=3600            # Session timeout in seconds

# Cloud Settings (for Render deployment)
RENDER_EXTERNAL_HOSTNAME=multichat-web.onrender.com  # Will be auto-set by Render
RENDER_EXTERNAL_URL=https://multichat-web.onrender.com  # Will be auto-set by Render
